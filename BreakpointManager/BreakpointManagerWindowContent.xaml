<UserControl x:Class="BreakpointManager.BreakpointManagerWindowContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BreakpointManager" xmlns:views="clr-namespace:BreakpointManager.Views"
             mc:Ignorable="d" 
             Background="{DynamicResource VsBrush.Window}"
             Foreground="{DynamicResource VsBrush.WindowText}"
             d:DesignHeight="450" d:DesignWidth="800"
             Name="BreakpointWindow">

    <TabControl>
        <TabItem Header="Breakpoints => Class">
            <views:BreakpointCommonView />
        </TabItem>

        <TabItem Header="TreeView">
            <views:BreakpointTreeView/>
        </TabItem>

    </TabControl>
    
</UserControl>
